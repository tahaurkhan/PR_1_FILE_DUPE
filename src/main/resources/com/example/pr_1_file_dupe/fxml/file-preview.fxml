<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="previewRoot" prefHeight="700.0" prefWidth="900.0"
    style="-fx-background-color: -surface;"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.pr_1_file_dupe.FilePreviewController">

    <!-- Top Bar with Close Button -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
            style="-fx-background-color: -surface-side; -fx-padding: 15 20;">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label fx:id="fileNameLabel"
                    style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -on-surface;"
                    text="File Name" />
                <Label fx:id="filePathLabel"
                    style="-fx-font-size: 12px; -fx-text-fill: -on-muted;"
                    text="File Path" />
            </VBox>

            <Button onAction="#closePreview"
                style="-fx-background-color: -danger; -fx-text-fill: white; 
                           -fx-font-weight: bold; -fx-background-radius: 8; 
                           -fx-padding: 10 20; -fx-font-size: 14px;"
                text="✕ Close" />
        </HBox>
    </top>

    <!-- Center - Preview Area -->
    <center>
        <VBox fx:id="previewContainer" alignment="CENTER" spacing="20"
            style="-fx-background-color: -surface; -fx-padding: 20;">

            <!-- Image Preview -->
            <ImageView fx:id="imagePreview"
                preserveRatio="true"
                fitWidth="800" fitHeight="500"
                visible="false" managed="false" />

            <!-- Text Preview -->
            <ScrollPane fitToWidth="true" fitToHeight="true"
                style="-fx-background-color: transparent;">
                <Label fx:id="textPreview"
                    wrapText="true"
                    style="-fx-font-family: 'Consolas', 'Monaco', monospace;
                              -fx-font-size: 12px; -fx-text-fill: -on-surface;
                              -fx-background-color: -surface-card; -fx-padding: 20;"
                    visible="false" managed="false" />
            </ScrollPane>
        </VBox>
    </center>

    <!-- Bottom - File Info -->
    <bottom>
        <HBox alignment="CENTER" spacing="40"
            style="-fx-background-color: -surface-side; -fx-padding: 15 20;">
            <VBox alignment="CENTER" spacing="5">
                <Label style="-fx-font-size: 11px; -fx-text-fill: -on-muted;" text="Size" />
                <Label fx:id="fileSizeLabel"
                    style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: -on-surface;"
                    text="0 KB" />
            </VBox>

            <VBox alignment="CENTER" spacing="5">
                <Label style="-fx-font-size: 11px; -fx-text-fill: -on-muted;" text="Type" />
                <Label fx:id="fileTypeLabel"
                    style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: -on-surface;"
                    text="TXT" />
            </VBox>
        </HBox>
    </bottom>

</BorderPane>