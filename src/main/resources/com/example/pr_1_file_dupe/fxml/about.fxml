        <Label wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d; -fx-text-alignment: center;" 
               text="A smart tool to find and remove duplicate files from your system" />
    </VBox>

    <!-- Developers Section -->
    <VBox spacing="20" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="👨‍💻 Development Team" />
        
        <!-- Developer 1 -->
