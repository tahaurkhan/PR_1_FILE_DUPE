      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pr_1_file_dupe.AboutController">

    <!-- App Header -->
    <VBox alignment="CENTER" spacing="8" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
