            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label style="-fx-font-size: 14px; -fx-text-fill: #2c3e50;" text="📧" />
                <Label style="-fx-font-size: 14px; -fx-text-fill: #2c3e50;" text="guptapraveen67984@gmail.com" />
