<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="25.0"
      alignment="TOP_CENTER"
      style="-fx-padding: 40px; -fx-background-color: #f8fcfd;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pr_1_file_dupe.SettingsController">
    
    <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" 
    text="Scan Preferences" />
    <Label style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;" 
    text="Customize how the engine searches for duplicate files." />

    <VBox spacing="20.0" 
    style="-fx-background-color: white; -fx-padding: 30px; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
        
        <VBox spacing="10.0">
            <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" 
            text="Comparison Algorithm" />
            <Label style="-fx-text-fill: #7f8c8d;" 
            text="SHA-256 is highly accurate. MD5 is faster for older machines." />
            <ComboBox fx:id="algoDropdown" 
            prefWidth="250.0">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="SHA-256" />
                        <String fx:value="MD5" />
                    </FXCollections>
                </items>
            </ComboBox>
        </VBox>

        <VBox spacing="10.0" style="-fx-padding: 20 0 0 0;">
            <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Exclusions &amp; Filters" />
            <CheckBox fx:id="skipHiddenCheckbox" style="-fx-font-size: 14px;" text="Skip hidden system files (Recommended)" />
            
            <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-padding: 10 0 0 0;">
                <Label style="-fx-font-size: 14px;" text="Ignore files smaller than:" />
                <TextField fx:id="minSizeInput" prefWidth="80.0" promptText="e.g. 10" />
                <Label style="-fx-font-size: 14px;" text="KB" />
            </HBox>
        </VBox>
        <!-- Dark Theme Toggle -->

<VBox spacing="15">

    <Label text="Appearance"/>

    <HBox spacing="10">
        <Label text="Dark Mode"/>
        <ToggleButton fx:id="darkModeToggle"/>
    </HBox>

    <HBox spacing="10">
        <Label text="Safe Mode"/>
        <ToggleButton fx:id="safeModeToggle"/>
    </HBox>

</VBox>

<!-- Safe Mode Toggle -->
<VBox spacing="10" style="-fx-padding: 10 0 0 0;">
    <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Safety" />
    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox>
            <Label style="-fx-font-size: 14px;" text="Safe Mode" />
            <Label fx:id="safeModeDesc"
                   style="-fx-text-fill: #27ae60; -fx-font-size: 12px;"
                   text="ON — Files moved to Trash (recoverable)" />
        </VBox>
        <HBox HBox.hgrow="ALWAYS"/>
        <ToggleButton fx:id="safeModeToggle"
                      onAction="#toggleSafeMode"
                      style="-fx-background-radius: 20; -fx-padding: 5 18;
                             -fx-font-weight: bold;"
                      text="ON" />
    </HBox>
</VBox>
    </VBox>

    <Button onAction="#saveSettings" prefHeight="45.0" prefWidth="150.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 10;" text="Save Settings" />
    <Label fx:id="statusLabel" style="-fx-text-fill: #2ecc71; -fx-font-weight: bold;" />

</VBox>