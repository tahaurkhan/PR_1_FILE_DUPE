<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="24" style="-fx-padding: 36; -fx-background-color: -surface;"
       xmlns="http://javafx.com/javafx/21"
       xmlns:fx="http://javafx.com/fxml/1"
       fx:controller="com.example.pr_1_file_dupe.RecoveryController">

       <!-- Header -->
       <VBox spacing="4">
              <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: -on-surface;"
                     text="Recovery &amp; History" />
              <Label style="-fx-font-size: 13px; -fx-text-fill: -on-muted;"
                     text="Track space reclaimed and manage files you have cleaned up." />
       </VBox>

       <!-- Stat Cards -->
       <HBox spacing="16">
              <VBox alignment="CENTER" prefHeight="110" HBox.hgrow="ALWAYS"
                     style="-fx-background-color: -surface-card; -fx-background-radius: 14;
                     -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 4);">
                     <Label style="-fx-font-size: 32px;" text="💾" />
                     <Label fx:id="spaceSavedLabel"
                            style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: -info;"
                            text="0 MB" />
                     <Label style="-fx-font-size: 12px; -fx-text-fill: -on-muted;"
                            text="Total Space Reclaimed" />
              </VBox>

              <VBox alignment="CENTER" prefHeight="110" HBox.hgrow="ALWAYS"
                     style="-fx-background-color: -surface-card; -fx-background-radius: 14;
                     -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 4);">
                     <Label style="-fx-font-size: 32px;" text="🗑" />
                     <Label fx:id="filesDeletedLabel"
                            style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: -danger;"
                            text="0" />
                     <Label style="-fx-font-size: 12px; -fx-text-fill: -on-muted;"
                            text="Groups Cleaned" />
              </VBox>

              <VBox alignment="CENTER" prefHeight="110" HBox.hgrow="ALWAYS"
                     style="-fx-background-color: -surface-card; -fx-background-radius: 14;
                     -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 4);">
                     <Label style="-fx-font-size: 32px;" text="🔎" />
                     <Label fx:id="scansRunLabel"
                            style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: -warning;"
                            text="0" />
                     <Label style="-fx-font-size: 12px; -fx-text-fill: -on-muted;"
                            text="Total Files Scanned" />
              </VBox>
       </HBox>

       <!-- Deletion Log -->
       <VBox spacing="10"
              style="-fx-background-color: -surface-card; -fx-background-radius: 14; -fx-padding: 20;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.07), 10, 0, 0, 4);">
              <HBox alignment="CENTER_LEFT" spacing="10">
                     <Label
                            style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: -on-surface;"
                            text="Session Deletion Log" />
                     <HBox HBox.hgrow="ALWAYS" />
                     <Button onAction="#clearLog"
                            style="-fx-background-color: -surface-side; -fx-text-fill: -on-muted;
                           -fx-background-radius: 6; -fx-font-size: 12px; -fx-padding: 5 12;"
                            text="Clear Log" />
              </HBox>

              <TableView fx:id="logTable" prefHeight="200" style="-fx-border-color: transparent;">
                     <columns>
                            <TableColumn fx:id="logTimeCol" prefWidth="130" text="Time" />
                            <TableColumn fx:id="logNameCol" prefWidth="260" text="File Name" />
                            <TableColumn fx:id="logSizeCol" prefWidth="100" text="Size" />
                            <TableColumn fx:id="logPathCol" prefWidth="300" text="Original Path" />
                     </columns>
                     <placeholder>
                            <Label style="-fx-text-fill: -on-muted; -fx-font-size: 13px;"
                                   text="No files have been deleted this session." />
                     </placeholder>
              </TableView>
       </VBox>

       <!-- Actions -->
       <HBox spacing="14">
              <Button onAction="#openTrash" prefHeight="44" HBox.hgrow="ALWAYS"
                     maxWidth="1.7976931348623157E308"
                     style="-fx-background-color: -info; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 10; -fx-font-size: 13px;"
                     text="📂  Open Trash / Recycle Bin" />
              <Button onAction="#resetStats" prefHeight="44" HBox.hgrow="ALWAYS"
                     maxWidth="1.7976931348623157E308"
                     style="-fx-background-color: -surface-side; -fx-text-fill: -danger;
                       -fx-font-weight: bold; -fx-background-radius: 10; -fx-font-size: 13px;"
                     text="⚠  Reset All Statistics" />
       </HBox>

       <!-- Tips panel -->
       <VBox spacing="8" styleClass="tip-panel">
              <Label style="-fx-font-size: 14px; -fx-font-weight: bold;"
                     text="💡 Recovery Tips" />
              <Label wrapText="true"
                     style="-fx-font-size: 12px;"
                     text="• Files are moved to your OS Trash — not permanently deleted. You can restore them from there." />
              <Label wrapText="true"
                     style="-fx-font-size: 12px;"
                     text="• Always keep the original copy in its primary location and delete the duplicate." />
              <Label wrapText="true"
                     style="-fx-font-size: 12px;"
                     text="• Run a scan again after cleanup to verify everything looks clean." />
       </VBox>

</VBox>