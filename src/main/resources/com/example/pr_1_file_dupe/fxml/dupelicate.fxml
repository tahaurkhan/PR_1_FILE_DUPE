<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="0" style="-fx-background-color: #f8fcfd;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pr_1_file_dupe.DuplicatesController">

    <!-- Header -->
    <VBox style="-fx-background-color: white; -fx-padding: 24 30 20 30;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 8, 0, 0, 3);">
        <HBox alignment="CENTER_LEFT" spacing="20">
            <VBox HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"
                       text="Duplicate Files" />
                <Label style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"
                       text="Review and clean up duplicate file groups from your last scan." />
            </VBox>

            <!-- Summary chips -->
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <VBox alignment="CENTER"
                      style="-fx-background-color: #eaf4fb; -fx-background-radius: 10; -fx-padding: 10 18;">
                    <Label fx:id="totalGroupsLabel"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2980b9;" text="0" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="Groups" />
                </VBox>
                <VBox alignment="CENTER"
                      style="-fx-background-color: #fef9e7; -fx-background-radius: 10; -fx-padding: 10 18;">
                    <Label fx:id="wastedSpaceLabel"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #e67e22;" text="0 KB" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="Wasted" />
                </VBox>
                <VBox alignment="CENTER"
                      style="-fx-background-color: #eafaf1; -fx-background-radius: 10; -fx-padding: 10 18;">
                    <Label fx:id="totalFilesLabel"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" text="0" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="Files" />
                </VBox>
            </HBox>
        </HBox>

        <!-- Filter bar -->
        <HBox spacing="8" style="-fx-padding: 16 0 0 0;">
            <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;
                          -fx-padding: 0 8 0 0;" text="Filter:" />
            <ToggleButton fx:id="filterAll" onAction="#applyFilter"
                          selected="true" text="All"
                          style="-fx-background-radius: 20; -fx-font-size: 12px;" />
            <ToggleButton fx:id="filterImages" onAction="#applyFilter"
                          text="🖼 Images"
                          style="-fx-background-radius: 20; -fx-font-size: 12px;" />
            <ToggleButton fx:id="filterVideos" onAction="#applyFilter"
                          text="🎬 Videos"
                          style="-fx-background-radius: 20; -fx-font-size: 12px;" />
            <ToggleButton fx:id="filterDocs" onAction="#applyFilter"
                          text="📄 Docs"
                          style="-fx-background-radius: 20; -fx-font-size: 12px;" />
            <ToggleButton fx:id="filterOthers" onAction="#applyFilter"
                          text="📦 Others"
                          style="-fx-background-radius: 20; -fx-font-size: 12px;" />

            <HBox HBox.hgrow="ALWAYS" />

            <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;" text="Sort by:" />
            <ComboBox fx:id="sortDropdown" onAction="#applySort" prefWidth="140">
                <items>
                    <javafx.collections.FXCollections fx:factory="observableArrayList">
                        <java.lang.String fx:value="Largest First" />
                        <java.lang.String fx:value="Smallest First" />
                        <java.lang.String fx:value="Most Copies" />
                        <java.lang.String fx:value="File Name A-Z" />
                    </javafx.collections.FXCollections>
                </items>
            </ComboBox>
        </HBox>
    </VBox>

    <!-- No data warning -->
    <VBox fx:id="noDataPane" alignment="CENTER" spacing="12"
          style="-fx-padding: 60;" visible="false" managed="false">
        <Label style="-fx-font-size: 40px;" text="🔍" />
        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"
               text="No scan data available" />
        <Label style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"
               text="Go to the Dashboard and run a scan first." />
    </VBox>

    <!-- Tree Table -->
    <TreeTableView fx:id="duplicatesTable" VBox.vgrow="ALWAYS"
                   style="-fx-border-color: transparent;" editable="true">
        <columns>
            <TreeTableColumn fx:id="selectCol"  prefWidth="60"  text="✓" />
            <TreeTableColumn fx:id="nameCol"    prefWidth="300" text="File Name / Group" />
            <TreeTableColumn fx:id="typeCol"    prefWidth="90"  text="Type" />
            <TreeTableColumn fx:id="sizeCol"    prefWidth="110" text="Size" />
            <TreeTableColumn fx:id="pathCol"    prefWidth="380" text="Path" />
        </columns>
    </TreeTableView>

    <!-- Bottom action bar -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: white; -fx-padding: 14 24;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 8, 0, -3, 0);">
        <Button onAction="#selectAll"
                style="-fx-background-color: #ecf0f1; -fx-text-fill: #2c3e50;
                       -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16;"
                text="Select All" />
        <Button onAction="#selectNone"
                style="-fx-background-color: #ecf0f1; -fx-text-fill: #2c3e50;
                       -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16;"
                text="Deselect All" />
        <Button onAction="#selectAllButFirst"
                style="-fx-background-color: #ecf0f1; -fx-text-fill: #2c3e50;
                       -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16;"
                text="Auto-Select Dupes" />

        <HBox HBox.hgrow="ALWAYS" />

        <Label fx:id="selectedCountLabel"
               style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;"
               text="0 files selected" />
        <Button onAction="#deleteSelected"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 8;
                       -fx-padding: 10 24; -fx-font-size: 14px;"
                text="🗑  Delete Selected" />
                
    </HBox>
    <Button onAction="#exportToCSV"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16;"
                text="📊 Export CSV" />
</VBox>