<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="30.0" style="-fx-background-color: -surface; -fx-padding: 40;"
    xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.pr_1_file_dupe.DashboardController">

    <VBox alignment="CENTER" spacing="5">
        <Label style="-fx-font-size: 14px; -fx-text-fill: -on-muted;"
            text="Monitor your storage and identify duplicate clusters." />
    </VBox>

    <HBox alignment="CENTER" spacing="25.0">
        <VBox alignment="CENTER" prefHeight="150.0" prefWidth="200.0"
            style="-fx-background-color: -surface-card; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <Label style="-fx-text-fill: -on-muted; -fx-font-size: 14px;" text="Space Saved" />
            <Label fx:id="totalSavedLabel"
                style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: -info;"
                text="0 KB" />
        </VBox>

        <VBox alignment="CENTER" prefHeight="150.0" prefWidth="200.0"
            style="-fx-background-color: -surface-card; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <Label style="-fx-text-fill: -on-muted; -fx-font-size: 14px;" text="Groups Found" />
            <Label fx:id="groupsFoundLabel"
                style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: -success;"
                text="0" />
        </VBox>

        <VBox alignment="CENTER" prefHeight="150.0" prefWidth="200.0"
            style="-fx-background-color: -surface-card; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <Label style="-fx-text-fill: -on-muted; -fx-font-size: 14px;" text="Total Scanned" />
            <Label fx:id="scannedCountLabel"
                style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: -warning;"
                text="0" />
        </VBox>
    </HBox>

    <HBox alignment="CENTER" spacing="10.0" />

    <Label prefHeight="46.0" prefWidth="216.0"
        style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: -on-surface;"
        text="System scan " />

    <Button onAction="#startFullSystemScan"
        prefHeight="45.0" prefWidth="200.0"
        style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"
        text="🌐 SCAN FULL SYSTEM" />

    <VBox alignment="CENTER" spacing="15"
        style="-fx-background-color: -surface-card; -fx-padding: 30; -fx-background-radius: 15;">
        <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Ready for a new scan?" />

        <TextField fx:id="pathInputField" prefHeight="45.0" prefWidth="450.0"
            promptText="Enter folder path..." style="-fx-background-radius: 10;" />

        <Button onAction="#browseFolder" prefHeight="45.0" prefWidth="100.0"
            style="-fx-background-color: -surface-side; -fx-text-fill: -on-surface; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"
            text="BROWSE" />

        <HBox alignment="CENTER" spacing="10.0">
            <Button fx:id="scanButton" onAction="#startScan" prefHeight="45.0" prefWidth="150.0"
                style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"
                text="START SCAN" />
        </HBox>

        <VBox fx:id="loadingBox" alignment="CENTER_LEFT" spacing="12.0" visible="false"
            style="-fx-background-color: -surface-side; -fx-background-radius: 14; -fx-padding: 24; -fx-max-width: 450; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 12, 0, 0, 5); -fx-border-color: -primary-light; -fx-border-width: 1; -fx-border-radius: 14;">

            <Label style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: -on-surface;"
                text="Scanning in progress..." />
            
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="scanCountLabel" style="-fx-text-fill: -on-muted; -fx-font-size: 13px; -fx-font-weight: bold;"
                    text="Items scanned: 0" />
            </HBox>

            <ProgressBar fx:id="scanProgressBar" prefWidth="410.0" prefHeight="12.0" progress="-1.0" />

            <Label fx:id="scanDetailsLabel" maxWidth="410"
                style="-fx-text-fill: -on-muted; -fx-font-size: 11px; -fx-font-family: 'Consolas', 'Courier New', monospace;" text="Name: Preparing..."
                wrapText="false" />

            <HBox alignment="CENTER_RIGHT" prefWidth="410.0" style="-fx-padding: 8 0 0 0;">
                <Button onAction="#cancelScan" text="Cancel Scan"
                    style="-fx-background-color: transparent; -fx-border-color: -danger; -fx-text-fill: -danger; -fx-border-radius: 8; -fx-cursor: hand; -fx-padding: 6 18; -fx-font-weight: bold; -fx-background-radius: 8;" />
            </HBox>
        </VBox>
    </VBox>

</VBox>