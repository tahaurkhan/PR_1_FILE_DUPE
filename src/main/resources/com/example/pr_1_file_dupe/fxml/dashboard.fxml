<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox alignment="TOP_CENTER" spacing="30.0" style="-fx-background-color: #f8fcfd; -fx-padding: 40;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pr_1_file_dupe.DashboardController">
    
    <VBox alignment="CENTER" spacing="5">
        <Label style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="System Overview" />
        <Label style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;" text="Monitor your storage and identify duplicate clusters." />
    </VBox>

    <HBox alignment="CENTER" spacing="25.0">
        <VBox alignment="CENTER" prefHeight="150.0" prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;" text="Space Saved" />
            <Label fx:id="totalSavedLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #00e5ff;" text="0 KB" />
        </VBox>

        <VBox alignment="CENTER" prefHeight="150.0" prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;" text="Groups Found" />
            <Label fx:id="groupsFoundLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;" text="0" />
        </VBox>

        <VBox alignment="CENTER" prefHeight="150.0" prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;" text="Total Scanned" />
            <Label fx:id="scannedCountLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e67e22;" text="0" />
        </VBox>
    </HBox>

    <VBox alignment="CENTER" spacing="15" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 15;">
        <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Ready for a new scan?" />
        <HBox alignment="CENTER" spacing="10.0">
            <TextField fx:id="pathInputField" prefHeight="45.0" prefWidth="450.0" promptText="Enter folder path..." style="-fx-background-radius: 10;" />
            <Button fx:id="scanButton" onAction="#startScan" prefHeight="45.0" prefWidth="150.0" style="-fx-background-color: #00e5ff; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" text="START SCAN" />
        </HBox>
        
        <VBox fx:id="loadingBox" alignment="CENTER" spacing="10.0" visible="false">
            <ProgressIndicator prefHeight="40.0" prefWidth="40.0" />
            <Label style="-fx-text-fill: #00e5ff;" text="Processing data..." />
        </VBox>
    </VBox>

</VBox>